{
  "expo": {
    "name": "Auto Cobranca Cobrador",
    "slug": "auto-cobranca-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "autocobranca",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necessario para registrar sua localizacao ao concluir ou falhar uma visita de cobranca.",
        "NSCameraUsageDescription": "Necessario para fotografar o comprovante de pagamento.",
        "NSPhotoLibraryUsageDescription": "Necessario para selecionar foto do comprovante de pagamento."
      }
    },
    "android": {
      "package": "com.autocobranca.cobrador",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "react-native-maps",
        {
          "googleMapsApiKey": ""
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necessario para registrar sua localizacao ao concluir ou falhar uma visita de cobranca."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Necessario para fotografar o comprovante de pagamento."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/eee68fc7-5051-48fa-bf66-2bc6aa04eaa7",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eee68fc7-5051-48fa-bf66-2bc6aa04eaa7"
      }
    },
    "owner": "eduardo54"
  }
}
