PORT=3000
FRONTEND_URL=http://localhost:3001
JWT_SECRET=change_me_to_a_long_random_secret_min_16_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
POSTGRES_USER=auto_cobranca_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=auto_cobranca
POSTGRES_PORT=5432
DATABASE_URL="postgresql://auto_cobranca_user:change_me@localhost:5432/auto_cobranca?schema=public"
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change_me_webhook_verify_token
WHATSAPP_COMPANY_ID=replace_with_company_id_from_database
WHATSAPP_PHONE_NUMBER_ID=replace_with_meta_phone_number_id
WHATSAPP_ACCESS_TOKEN=replace_with_meta_access_token
# Para testar sem token real, use o modo simulado:
WHATSAPP_MOCK_MODE=false
# Provedores de IA (opcionais — sem chave, o agente usa analise mock).
# O agente de cobranca usa o Gemini por padrao.
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here
REDIS_URL=redis://localhost:6379
